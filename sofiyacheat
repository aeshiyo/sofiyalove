-- Полный экран (Смена размера с анимацией)
local isFullscreen = false
local normalSize = UDim2.new(0, 850, 0, 550)
local fullscreenSize = UDim2.new(1, 0, 1, 0)

FullBtn.MouseButton1Click:Connect(function()
    isFullscreen = not isFullscreen
    local targetSize = isFullscreen and fullscreenSize or normalSize
    local targetRadius = isFullscreen and UDim.new(0, 0) or UDim.new(0, 12)
    
    local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    
    TweenService:Create(MainWindow, tweenInfo, {Size = targetSize, Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
    TweenService:Create(MainUICorner, tweenInfo, {CornerRadius = targetRadius}):Play()
end)

