    end
    setupBind(FlyBindBtn, "Fly") setupBind(NoclipBindBtn, "Noclip") setupBind(SpeedBindBtn, "Speed") 
    setupBind(SitBindBtn, "Sit") setupBind(ShiftLockBindBtn, "ShiftLock") setupBind(SpinBindBtn, "Spin") setupBind(LowGfxBindBtn, "LowGraphics")

    UserInputService.InputBegan:Connect(function(input, gp)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            for keyName, binding in pairs(isBinding) do
                if binding then
                    local btnUI = keyName == "Fly" and FlyBindBtn or keyName == "Noclip" and NoclipBindBtn or keyName == "Speed" and SpeedBindBtn or keyName == "Sit" and SitBindBtn or keyName == "ShiftLock" and ShiftLockBindBtn or keyName == "Spin" and SpinBindBtn or LowGfxBindBtn
                    if input.KeyCode == Enum.KeyCode.Escape then
                        binds[keyName] = nil btnUI.Text = "[NONE]"
                    else
                        binds[keyName] = input.KeyCode btnUI.Text = "[" .. tostring(input.KeyCode):gsub("Enum.KeyCode.", "") .. "]"
                    end
                    isBinding[keyName] = false return
                end
            end
        end
        
        if not gp then
            if binds.Fly and input.KeyCode == binds.Fly then toggleFly() end
            if binds.Noclip and input.KeyCode == binds.Noclip then toggleNoclip() end
            if binds.Speed and input.KeyCode == binds.Speed then toggleSpeedhack() end
            if binds.Sit and input.KeyCode == binds.Sit then toggleSit() end
            if binds.ShiftLock and input.KeyCode == binds.ShiftLock then toggleShiftLock() end
            if binds.Spin and input.KeyCode == binds.Spin then toggleSpin() end
            if binds.LowGraphics and input.KeyCode == binds.LowGraphics then toggleLowGraphics() end
        end
    end)
