-- Функция создания кнопок управления
local function createControlBtn(name, text, order)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 25, 0, 25)
    btn.BackgroundColor3 = Color3.fromRGB(13, 13, 13)
    btn.Text = text
    btn.Font = Enum.Font.RobotoMono
    btn.TextSize = 14
    btn.TextColor3 = Color3.fromRGB(85, 85, 85)
    btn.LayoutOrder = order
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(68, 68, 68)
    stroke.Parent = btn
    
    -- Анимация наведения
    local hoverInfo = TweenInfo.new(0.2, Enum.EasingStyle.Sine)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, hoverInfo, {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        TweenService:Create(stroke, hoverInfo, {Color = Color3.fromRGB(255, 255, 255)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, hoverInfo, {TextColor3 = Color3.fromRGB(85, 85, 85)}):Play()
        TweenService:Create(stroke, hoverInfo, {Color = Color3.fromRGB(68, 68, 68)}):Play()
    end)
    
    return btn
end

