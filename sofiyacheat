    -- === LOW GRAPHICS ЛОГИКА ===
    local isLowGraphics = false
    local originalSettings = { Lighting = {}, Terrain = {}, Objects = {} }
    
    local function toggleLowGraphics()
        local Workspace = game:GetService("Workspace")
        local Terrain = Workspace:FindFirstChildOfClass("Terrain")
        isLowGraphics = not isLowGraphics
        
        if isLowGraphics then
            LowGfxToggle.BackgroundColor3 = Color3.fromRGB(10, 30, 10)
            LowGfxStroke.Color = Color3.fromRGB(50, 150, 50)
            LowGfxMobileBtn.BackgroundColor3 = Color3.fromRGB(10, 30, 10)
            
            pcall(function()
                originalSettings.Lighting.GlobalShadows = Lighting.GlobalShadows
                originalSettings.Lighting.FogEnd = Lighting.FogEnd
                originalSettings.Lighting.Brightness = Lighting.Brightness
                originalSettings.Lighting.Ambient = Lighting.Ambient
                
                Lighting.GlobalShadows = false
                Lighting.FogEnd = 0
                Lighting.Brightness = 0.3
                Lighting.Ambient = Color3.fromRGB(80, 80, 80)
            end)
            
            for _, v in ipairs(Lighting:GetChildren()) do
                if v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("SunRaysEffect") then
                    pcall(function() originalSettings.Objects[v] = { Enabled = v.Enabled } v.Enabled = false end)
                end
            end
            
            if Terrain then
                pcall(function()
                    originalSettings.Terrain.WaterWaveSize = Terrain.WaterWaveSize
                    originalSettings.Terrain.WaterWaveSpeed = Terrain.WaterWaveSpeed
                    originalSettings.Terrain.WaterReflectance = Terrain.WaterReflectance
                    Terrain.WaterWaveSize = 0 Terrain.WaterWaveSpeed = 0 Terrain.WaterReflectance = 0
                end)
            end
            
            for _, v in ipairs(Workspace:GetDescendants()) do
                if v:IsA("BasePart") then
                    pcall(function()
                        originalSettings.Objects[v] = { Material = v.Material, Reflectance = v.Reflectance, Transparency = v.Transparency }
                        v.Material = Enum.Material.SmoothPlastic v.Reflectance = 0
                        if v.Material ~= Enum.Material.Glass and v.Material ~= Enum.Material.Water then v.Transparency = 0 end
                    end)
                end
                if v:IsA("SpecialMesh") then
                    pcall(function() originalSettings.Objects[v] = { MeshType = v.MeshType } v.MeshType = Enum.MeshType.Brick end)
                end
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") then
                    pcall(function() originalSettings.Objects[v] = { Enabled = v.Enabled } v.Enabled = false end)
                end
                if v:IsA("Decal") or v:IsA("Texture") then
                    pcall(function() originalSettings.Objects[v] = { Transparency = v.Transparency } v.Transparency = 1 end)
                end
                if v:IsA("Humanoid") then
                    pcall(function()
                        local animator = v:FindFirstChildOfClass("Animator")
                        if animator then
                            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                                originalSettings.Objects[track] = { Speed = track.Speed } track:AdjustSpeed(0)
                            end
                        end
                    end)
                end
            end
        else
            LowGfxToggle.BackgroundColor3 = Color3.fromRGB(30, 10, 10)
            LowGfxStroke.Color = Color3.fromRGB(150, 50, 50)
            LowGfxMobileBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            
            pcall(function()
                if originalSettings.Lighting.GlobalShadows ~= nil then Lighting.GlobalShadows = originalSettings.Lighting.GlobalShadows end
                if originalSettings.Lighting.FogEnd ~= nil then Lighting.FogEnd = originalSettings.Lighting.FogEnd end
                if originalSettings.Lighting.Brightness ~= nil then Lighting.Brightness = originalSettings.Lighting.Brightness end
                if originalSettings.Lighting.Ambient ~= nil then Lighting.Ambient = originalSettings.Lighting.Ambient end
            end)
            
            if Terrain then
                pcall(function()
                    if originalSettings.Terrain.WaterWaveSize ~= nil then Terrain.WaterWaveSize = originalSettings.Terrain.WaterWaveSize end
                    if originalSettings.Terrain.WaterWaveSpeed ~= nil then Terrain.WaterWaveSpeed = originalSettings.Terrain.WaterWaveSpeed end
                    if originalSettings.Terrain.WaterReflectance ~= nil then Terrain.WaterReflectance = originalSettings.Terrain.WaterReflectance end
                end)
            end
            
            for obj, props in pairs(originalSettings.Objects) do
                if obj and obj.Parent or obj:IsA("AnimationTrack") then
                    pcall(function()
                        for propName, propValue in pairs(props) do
                            if propName == "Speed" and obj:IsA("AnimationTrack") then obj:AdjustSpeed(propValue) else obj[propName] = propValue end
                        end
                    end)
                end
            end
            originalSettings.Objects = {} originalSettings.Lighting = {} originalSettings.Terrain = {}
        end
    end
    LowGfxToggle.MouseButton1Click:Connect(toggleLowGraphics)

    -- === ОБРАБОТКА СЛАЙДЕРОВ ===
    local function setupSlider(sliderBtn, fill, label, minV, maxV, varName, prefix)
        local isSliding = false
        sliderBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = true end end)
        UserInputService.InputChanged:Connect(function(input)
            if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local pos = math.clamp((input.Position.X - sliderBtn.Parent.AbsolutePosition.X) / sliderBtn.Parent.AbsoluteSize.X, 0, 1)
                fill.Size = UDim2.new(pos, 0, 1, 0)
                local val = math.floor(minV + (maxV - minV) * pos)
                label.Text = prefix .. ": " .. val
                if varName == "flySpeed" then flySpeed = val
                elseif varName == "walkSpeedMod" then walkSpeedMod = val
                elseif varName == "spinSpeedMod" then spinSpeedMod = val end
            end
        end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = false end end)
    end
    setupSlider(FlySlider, FlyFill, FlyLabel, 10, 200, "flySpeed", "Скорость")
    setupSlider(SpeedSlider, SpeedFill, SpeedLabel, 16, 250, "walkSpeedMod", "WalkSpeed")
    setupSlider(SpinSlider, SpinFill, SpinLabel, 5, 100, "spinSpeedMod", "Скорость вращения")

    -- =============================================
    -- === ИСПРАВЛЕННЫЕ МОБИЛЬНЫЕ КНОПКИ ===
    -- =============================================
    local function makeMobileBtnDraggable(btn, actionFunc)
        local dragging = false
        local dragInput = nil
        local dragStart, startPos = nil, nil
        local hasMoved = false
        local isLocked = false
        local holdTick = 0

        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                hasMoved = false
                dragInput = input
                dragStart = input.Position
                startPos = btn.Position
                holdTick = tick()

                task.spawn(function()
                    while dragging and not hasMoved do
                        -- Если удерживаем 1.5 секунды, переключаем блокировку позиции
                        if tick() - holdTick >= 1.5 then
                            isLocked = not isLocked
                            btn.BackgroundColor3 = isLocked and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(15, 15, 15)
                            btn.BackgroundTransparency = isLocked and 0.7 or 0.3
                            dragging = false -- Отменяем перетаскивание после блокировки
                            break
                        end
                        task.wait(0.1)
                    end
                end)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            -- Обновляем позицию только если это тот же палец и кнопка не заблокирована
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                if delta.Magnitude > 10 then
                    hasMoved = true
                end
                if hasMoved and not isLocked then
                    btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end
        end)

        btn.InputEnded:Connect(function(input)
            -- Выполняем функцию клика, только если отпустили ИМЕННО ЭТУ кнопку (лечит баг при беге)
            if input == dragInput then
                dragging = false
                if not hasMoved then
                    local holdTime = tick() - holdTick
                    -- Если отпустили быстро (< 1.5 сек), засчитываем как клик (даже если кнопка Locked)
                    if holdTime < 1.5 then
                        actionFunc()
                    end
                end
            end
        end)
    end

    makeMobileBtnDraggable(FlyMobileBtn, toggleFly)
