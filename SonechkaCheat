            boolBtn.TextColor3 = isShown and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
            boolBtn.BackgroundColor3 = isShown and Color3.fromRGB(10, 30, 10) or Color3.fromRGB(30, 10, 10)
