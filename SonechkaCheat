    -- === ЛОГИКА ESP ===
    local isESP = false
    local espCache = {}
    local R15_Bones = { {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"}, {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"} }
    local R6_Bones = { {"Head", "Torso"}, {"Torso", "Right Arm"}, {"Torso", "Left Arm"}, {"Torso", "Right Leg"}, {"Torso", "Left Leg"} }

    local function getESPColor(health, maxHealth)
        local hpFactor = math.clamp(health / maxHealth, 0, 1)
        return Color3.new(1 - hpFactor, hpFactor, 0)
    end

    local function checkVisibility(targetPart)
        local origin = Camera.CFrame.Position
        local direction = targetPart.Position - origin
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        raycastParams.IgnoreWater = true
        local result = workspace:Raycast(origin, direction, raycastParams)
        if result and result.Instance and not result.Instance:IsDescendantOf(targetPart.Parent) then
            return false
        end
        return true
    end

    local function createESPObj(player)
        local obj = {
            Box = Drawing.new("Square"), Name = Drawing.new("Text"), Dist = Drawing.new("Text"), HP = Drawing.new("Text"), Tracer = Drawing.new("Line"), HeadDot = Drawing.new("Circle"), SkeletonLines = {}, ChamsHighlight = Instance.new("Highlight")
        }
        obj.Box.Thickness = 1.5 obj.Box.Filled = false
        obj.Name.Size = 14 obj.Name.Center = true obj.Name.Outline = true obj.Name.Color = Color3.new(1, 1, 1)
        obj.Dist.Size = 13 obj.Dist.Center = true obj.Dist.Outline = true obj.Dist.Color = Color3.fromRGB(150, 150, 255)
        obj.HP.Size = 13 obj.HP.Center = true obj.HP.Outline = true
        obj.Tracer.Thickness = 1
        obj.HeadDot.Radius = 3 obj.HeadDot.Filled = true obj.HeadDot.Color = Color3.new(1, 0, 0)
        for i = 1, 15 do
            local line = Drawing.new("Line") line.Thickness = 1.5 line.Color = Color3.new(0.5, 0.8, 1) table.insert(obj.SkeletonLines, line)
        end
        obj.ChamsHighlight.FillTransparency = 0.5 obj.ChamsHighlight.OutlineTransparency = 0.1
        espCache[player] = obj return obj
    end

    local function updateESP()
        if not isESP then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local char = player.Character
                local hum = char and char:FindFirstChild("Humanoid")
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local head = char and char:FindFirstChild("Head")
                local obj = espCache[player] or createESPObj(player)
                
                if char and hum and hrp and head and hum.Health > 0 then
                    local hrpPos, hrpOnScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if hrpOnScreen then
                        local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                        local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                        local boxHeight = math.abs(headPos.Y - legPos.Y)
                        local boxWidth = boxHeight * 0.6
                        local hpColor = getESPColor(hum.Health, hum.MaxHealth)
                        local isVisible = checkVisibility(head)
                        local trans = isVisible and 1 or 0.5
                        
                        obj.Box.Size = Vector2.new(boxWidth, boxHeight) obj.Box.Position = Vector2.new(hrpPos.X - boxWidth / 2, headPos.Y) obj.Box.Color = hpColor obj.Box.Transparency = trans obj.Box.Visible = true
                        local nameTxt = player.Name
                        if hum.SeatPart then nameTxt = nameTxt .. " [VEHICLE]" end
                        obj.Name.Text = nameTxt obj.Name.Position = Vector2.new(hrpPos.X, headPos.Y - 16) obj.Name.Transparency = trans obj.Name.Visible = true
                        obj.Dist.Text = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude) .. "m" obj.Dist.Position = Vector2.new(hrpPos.X, headPos.Y - 30) obj.Dist.Transparency = trans obj.Dist.Visible = true
                        obj.HP.Text = math.floor((hum.Health / hum.MaxHealth) * 100) .. "%" obj.HP.Color = hpColor obj.HP.Position = Vector2.new(hrpPos.X + boxWidth / 2 + 5, headPos.Y + boxHeight - 15) obj.HP.Transparency = trans obj.HP.Visible = true
                        obj.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) obj.Tracer.To = Vector2.new(hrpPos.X, legPos.Y) obj.Tracer.Color = hpColor obj.Tracer.Transparency = trans obj.Tracer.Visible = true
                        local headPoint = Camera:WorldToViewportPoint(head.Position) obj.HeadDot.Position = Vector2.new(headPoint.X, headPoint.Y) obj.HeadDot.Transparency = trans obj.HeadDot.Visible = true
                        
                        if obj.ChamsHighlight.Parent ~= char then obj.ChamsHighlight.Parent = char end
                        obj.ChamsHighlight.FillColor = hpColor obj.ChamsHighlight.OutlineColor = Color3.new(1,1,1)
                        for _, part in ipairs(char:GetChildren()) do if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Material ~= Enum.Material.Neon then part.Material = Enum.Material.Neon end end
                        
                        local isR15 = char:FindFirstChild("UpperTorso") ~= nil
                        local bones = isR15 and R15_Bones or R6_Bones
                        for i, line in ipairs(obj.SkeletonLines) do
                            local bonePair = bones[i]
                            if bonePair and char:FindFirstChild(bonePair[1]) and char:FindFirstChild(bonePair[2]) then
                                local p1Pos, p1Vis = Camera:WorldToViewportPoint(char[bonePair[1]].Position)
                                local p2Pos, p2Vis = Camera:WorldToViewportPoint(char[bonePair[2]].Position)
                                if p1Vis and p2Vis then line.From = Vector2.new(p1Pos.X, p1Pos.Y) line.To = Vector2.new(p2Pos.X, p2Pos.Y) line.Transparency = trans line.Visible = true else line.Visible = false end
                            else line.Visible = false end
                        end
                    else
                        obj.Box.Visible = false obj.Name.Visible = false obj.Dist.Visible = false obj.HP.Visible = false obj.Tracer.Visible = false obj.HeadDot.Visible = false
                        for _, line in ipairs(obj.SkeletonLines) do line.Visible = false end
                        if obj.ChamsHighlight.Parent then obj.ChamsHighlight.Parent = nil end
                    end
                else
                    if obj then
                        obj.Box.Visible = false obj.Name.Visible = false obj.Dist.Visible = false obj.HP.Visible = false obj.Tracer.Visible = false obj.HeadDot.Visible = false
                        for _, line in ipairs(obj.SkeletonLines) do line.Visible = false end
                        if obj.ChamsHighlight.Parent then obj.ChamsHighlight.Parent = nil end
                    end
                end
            end
        end
    end

