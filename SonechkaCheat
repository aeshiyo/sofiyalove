    -- === БИНДЫ С КЛАВИАТУРЫ ===
    local function setupBind(btn, keyName)
        btn.MouseButton1Click:Connect(function() btn.Text = "..." isBinding[keyName] = true end)
    end
   setupBind(LowGfxBindBtn, "LowGraphics") setupBind(ESPBindBtn, "ESP") setupBind(AimBindBtn, "Aimbot") setupBind(InfSlideBindBtn, "InfSlide")

    UserInputService.InputBegan:Connect(function(input, gp)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            for keyName, binding in pairs(isBinding) do
                if binding then
                   local btnUI = keyName == "Fly" and FlyBindBtn or keyName == "Noclip" and NoclipBindBtn or keyName == "Speed" and SpeedBindBtn or keyName == "Sit" and SitBindBtn or keyName == "ShiftLock" and ShiftLockBindBtn or keyName == "Spin" and SpinBindBtn or keyName == "LowGraphics" and LowGfxBindBtn or keyName == "ESP" and ESPBindBtn or keyName == "InfSlide" and InfSlideBindBtn or AimBindBtn
                    if input.KeyCode == Enum.KeyCode.Escape then
                        if keyName == "Aimbot" then
                            AimbotSettings.Bind = Enum.KeyCode.LeftAlt
                            btnUI.Text = "[LeftAlt]"
                        else
                            binds[keyName] = nil btnUI.Text = "[NONE]"
                        end
                    else
                        if keyName == "Aimbot" then
                            AimbotSettings.Bind = input.KeyCode
                        else
                            binds[keyName] = input.KeyCode
                        end
                        btnUI.Text = "[" .. tostring(input.KeyCode):gsub("Enum.KeyCode.", "") .. "]"
                    end
                    isBinding[keyName] = false return
                end
            end
        end
        
        if not gp then
            if binds.Fly and input.KeyCode == binds.Fly then toggleFly() end
            if binds.Noclip and input.KeyCode == binds.Noclip then toggleNoclip() end
            if binds.Speed and input.KeyCode == binds.Speed then toggleSpeedhack() end
            if binds.Sit and input.KeyCode == binds.Sit then toggleSit() end
            if binds.ShiftLock and input.KeyCode == binds.ShiftLock then toggleShiftLock() end
            if binds.Spin and input.KeyCode == binds.Spin then toggleSpin() end
            if binds.LowGraphics and input.KeyCode == binds.LowGraphics then toggleLowGraphics() end
            if binds.ESP and input.KeyCode == binds.ESP then toggleESP() end
            if binds.InfSlide and input.KeyCode == binds.InfSlide then toggleInfSlide() end
            -- AimbotBind обрабатывается внутри RenderStepped через IsKeyDown, поэтому тут вызова нет
        end
    end)
