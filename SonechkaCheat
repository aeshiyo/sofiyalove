    local function FindTarget()
        local closestTarget = nil
        local shortestDist = AimbotSettings.FOV
        local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChild("Humanoid") then
                if p.Character.Humanoid.Health > 0 then
                    -- TeamCheck (работает только если в игре есть команды)
                    if AimbotSettings.TeamCheck and p.Team ~= nil and LocalPlayer.Team ~= nil and p.Team == LocalPlayer.Team then continue end
                    
                    local headPos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
                    if onScreen then
                        local dist = (Vector2.new(headPos.X, headPos.Y) - screenCenter).Magnitude
                        if dist < shortestDist then
                            shortestDist = dist
                            closestTarget = p
                        end
                    end
                end
            end
        end
        return closestTarget
    end

    local function SmoothAim(target)
        if not target or not target.Character or not target.Character:FindFirstChild("Head") then return end
        
        local headPos, onScreen = Camera:WorldToViewportPoint(target.Character.Head.Position)
        if onScreen then
            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local deltaX = headPos.X - screenCenter.X
            local deltaY = headPos.Y - screenCenter.Y
            
            if AimbotSettings.Smoothness == 1 then
                mousemoverel(deltaX, deltaY)
            else
                mousemoverel(deltaX / AimbotSettings.Smoothness, deltaY / AimbotSettings.Smoothness)
            end
        end
    end

    -- Основной цикл Aimbot и обновление FOV
    RunService.RenderStepped:Connect(function()
        if AimbotSettings.Enabled then
            -- Обновление позиции и размера круга FOV (для FPS игр это всегда центр)
            FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            FOVCircle.Radius = AimbotSettings.FOV
            
            if UserInputService:IsKeyDown(AimbotSettings.Bind) then
                local target = FindTarget()
                if target then
                    FOVCircle.Color = Color3.fromRGB(50, 255, 50) -- Цель найдена (Зеленый)
                    SmoothAim(target)
                else
                    FOVCircle.Color = Color3.fromRGB(255, 50, 50) -- Нет цели (Красный)
                end
            else
                FOVCircle.Color = Color3.fromRGB(255, 50, 50) -- Клавиша не нажата
            end
        end
    end)


    -- === ОБРАБОТКА СЛАЙДЕРОВ ===
    local function setupSlider(sliderBtn, fill, label, minV, maxV, varName, prefix)
        local isSliding = false
        sliderBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = true end end)
        UserInputService.InputChanged:Connect(function(input)
            if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local pos = math.clamp((input.Position.X - sliderBtn.Parent.AbsolutePosition.X) / sliderBtn.Parent.AbsoluteSize.X, 0, 1)
                fill.Size = UDim2.new(pos, 0, 1, 0)
                local val = math.floor(minV + (maxV - minV) * pos)
                label.Text = prefix .. ": " .. val
                
                if varName == "flySpeed" then flySpeed = val
                elseif varName == "walkSpeedMod" then walkSpeedMod = val
                elseif varName == "spinSpeedMod" then spinSpeedMod = val 
                elseif varName == "AimFOV" then AimbotSettings.FOV = val
                elseif varName == "AimSmooth" then AimbotSettings.Smoothness = val end
            end
        end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = false end end)
    end
    setupSlider(FlySlider, FlyFill, FlyLabel, 10, 200, "flySpeed", "Скорость")
    setupSlider(SpeedSlider, SpeedFill, SpeedLabel, 16, 250, "walkSpeedMod", "WalkSpeed")
    setupSlider(SpinSlider, SpinFill, SpinLabel, 5, 100, "spinSpeedMod", "Скорость вращения")
    setupSlider(AimFOVSlider, AimFOVFill, AimFOVLabel, 0, 360, "AimFOV", "Радиус FOV")
    setupSlider(AimSmoothSlider, AimSmoothFill, AimSmoothLabel, 1, 20, "AimSmooth", "Плавность")

    -- === ОБРАБОТКА МОБИЛЬНЫХ КНОПОК ===
    local function makeMobileBtnDraggable(btn, actionFunc)
        local dragging = false
        local dragInput = nil
        local dragStart, startPos = nil, nil
        local hasMoved = false
        local isLocked = false
        local holdTick = 0

        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true hasMoved = false dragInput = input
                dragStart = input.Position startPos = btn.Position holdTick = tick()

                task.spawn(function()
                    while dragging and not hasMoved do
                        if tick() - holdTick >= 1.5 then
                            isLocked = not isLocked
                            btn.BackgroundColor3 = isLocked and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(15, 15, 15)
                            btn.BackgroundTransparency = isLocked and 0.7 or 0.3
                            dragging = false
                            break
                        end
                        task.wait(0.1)
                    end
                end)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                if delta.Magnitude > 10 then hasMoved = true end
                if hasMoved and not isLocked then
                    btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end
        end)

        btn.InputEnded:Connect(function(input)
            if input == dragInput then
                dragging = false
                if not hasMoved then
                    if tick() - holdTick < 1.5 then actionFunc() end
                end
            end
        end)
    end

    makeMobileBtnDraggable(FlyMobileBtn, toggleFly)
    makeMobileBtnDraggable(NoclipMobileBtn, toggleNoclip)
    makeMobileBtnDraggable(SpeedMobileBtn, toggleSpeedhack)
